{
  "name": "rostr-agent-platform",
  "version": "1.0.0",
  "description": "Self-improving multi-agent framework with PAL, NPAO, RAG DAL, and Rostr Hub",
  "main": "api-server.js",
  "scripts": {
    "start": "node api-server.js",
    "dev": "nodemon api-server.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:e2e": "jest --testPathPattern=e2e",
    "test:integration": "jest --testPathPattern=integration",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "build:docker": "docker build -t rostr-agent:latest .",
    "deploy:terraform": "terraform apply -auto-approve",
    "eval": "node evals/runner.js",
    "eval:baseline": "node evals/runner.js --baseline",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.87.0",
    "aws-sdk": "^2.1400.0",
    "bcrypt": "^5.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.1.0",
    "pydantic-core": "^2.0.0",
    "sqlite3": "^5.1.6",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/jest": "^29.5.3",
    "@types/node": "^20.4.5",
    "eslint": "^8.46.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "prettier": "^3.0.1",
    "typescript": "^5.1.6"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "agent",
    "orchestration",
    "PAL",
    "NPAO",
    "RAG",
    "multi-agent",
    "hermes"
  ],
  "author": "Patrick Diamitani",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/diamitani/rostr-agent.git"
  }
}
