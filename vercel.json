{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "portfolio.diamitani.com" }],
      "destination": "/portfolio"
    },
    {
      "source": "/:path((?!assets/|api/|portfolio).*)",
      "has": [{ "type": "host", "value": "portfolio.diamitani.com" }],
      "destination": "/portfolio/:path"
    },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "industries.diamitani.com" }],
      "destination": "/industries"
    },
    {
      "source": "/:path((?!assets/|api/|industries).*)",
      "has": [{ "type": "host", "value": "industries.diamitani.com" }],
      "destination": "/industries/:path"
    },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "art.diamitani.com" }],
      "destination": "/art"
    },
    {
      "source": "/:path((?!assets/|api/|art).*)",
      "has": [{ "type": "host", "value": "art.diamitani.com" }],
      "destination": "/art/:path"
    },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "music.diamitani.com" }],
      "destination": "/music"
    },
    {
      "source": "/:path((?!assets/|api/|music).*)",
      "has": [{ "type": "host", "value": "music.diamitani.com" }],
      "destination": "/music/:path"
    },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "label.diamitani.com" }],
      "destination": "/diamitani-music"
    },
    {
      "source": "/:path((?!assets/|api/|diamitani-music).*)",
      "has": [{ "type": "host", "value": "label.diamitani.com" }],
      "destination": "/diamitani-music/:path"
    }
  ]
}
